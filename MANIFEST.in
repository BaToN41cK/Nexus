# Include config templates
include nexus/config/.env.example
include nexus/config/nexus.yaml
recursive-include nexus/config *

# Include locale translations
recursive-include nexus/locale *.json

# Include documentation
include README.md
include requirements.txt

# Exclude compiled and cache files
global-exclude __pycache__/
global-exclude *.py[cod]
global-exclude *.so
global-exclude .DS_Store